// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum TitleType {
  ANIME
  MANHWA
  MOVIE
}

enum WatchStatus {
  PLAN_TO_WATCH
  WATCHING
  COMPLETED
  DROPPED
}

model User {
  id            String     @id @default(cuid())
  username      String     @unique
  email         String     @unique
  passwordHash  String
  role          Role       @default(USER)
  profileImage  String?
  bio           String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  titles        Title[]    @relation("TitleCreator")
  reviews       Review[]
  watchlist     Watchlist[]
  favorites     Favorite[]
  votes         ReviewVote[]
  replies       ReviewReply[]

  @@index([email])
  @@index([username])
}

model Title {
  id            String     @id @default(cuid())
  name          String
  normalizedName String?
  description   String     @db.Text
  releaseYear   Int
  type          TitleType
  coverImage    String?
  genres        String[]   @default([])
  creatorId     String?    @map("createdById")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // Relations
  creator       User?      @relation("TitleCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  reviews       Review[]
  watchlist     Watchlist[]
  favorites     Favorite[]

  @@unique([normalizedName, type])
  @@index([type])
  @@index([name])
  @@index([creatorId])
}

model Review {
  id            String     @id @default(cuid())
  rating        Int        // 1-10 rating
  content       String     @db.Text
  helpful       Int        @default(0)
  notHelpful    Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  userId        String
  titleId       String
  
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         Title      @relation(fields: [titleId], references: [id], onDelete: Cascade)
  
  votes         ReviewVote[]
  replies       ReviewReply[]

  @@unique([userId, titleId]) // One review per user per title
  @@index([titleId])
  @@index([userId])
}

model ReviewVote {
  id            String     @id @default(cuid())
  isHelpful     Boolean    // true = helpful, false = not helpful
  createdAt     DateTime   @default(now())

  userId        String
  reviewId      String

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  review        Review     @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([userId, reviewId]) // One vote per user per review
  @@index([reviewId])
}

model ReviewReply {
  id            String     @id @default(cuid())
  content       String     @db.Text
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  userId        String
  reviewId      String

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  review        Review     @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([userId])
}

model Watchlist {
  id            String     @id @default(cuid())
  status        WatchStatus
  addedAt       DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  userId        String
  titleId       String

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         Title      @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@unique([userId, titleId])
  @@index([userId])
  @@index([titleId])
  @@index([status])
}

model Favorite {
  id            String     @id @default(cuid())
  addedAt       DateTime   @default(now())

  userId        String
  titleId       String

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         Title      @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@unique([userId, titleId])
  @@index([userId])
  @@index([titleId])
}
