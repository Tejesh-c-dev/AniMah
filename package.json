{
  "name": "animah",
  "version": "1.0.0",
  "description": "Community platform for tracking anime, manhwa, and movies",
  "main": "server/dist/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "nodemon --watch server/src --exec ts-node -P server/tsconfig.json server/src/index.ts",
    "dev:web": "next dev",
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc -p server/tsconfig.json",
    "build:web": "next build",
    "start": "node server/dist/index.js & next start",
    "lint": "eslint . --ext .ts,.tsx --ignore-path .gitignore",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "formidable": "^2.1.1",
    "framer-motion": "^10.16.4",
    "jsonwebtoken": "^9.0.0",
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.3.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.3",
    "@types/express": "^4.17.17",
    "@types/formidable": "^3.4.5",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "autoprefixer": "^10.4.14",
    "concurrently": "^8.2.0",
    "eslint": "^8.44.0",
    "eslint-config-next": "^14.0.0",
    "nodemon": "^3.0.1",
    "postcss": "^8.4.24",
    "prisma": "^5.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.0"
  }
}
