# Database
DATABASE_URL="postgresql://[user]:[password]@[host]-pooler.neon.tech/[dbname]?sslmode=require&connect_timeout=15"
DIRECT_URL="postgresql://[user]:[password]@[host].neon.tech/[dbname]?sslmode=require&connect_timeout=15"

# JWT & Auth
# JWT_SECRET: Must be at least 32 characters. Use a secure random string.
# Generate with: openssl rand -base64 48
JWT_SECRET="replace_with_a_random_64_char_secret_for_jwt_signing_1234567890"

# ADMIN_SETUP_KEY: One-time use key to create the first admin account.
# Must be at least 32 characters. Keep this SECRET - do not commit to version control.
# Generate with: openssl rand -base64 48
# After creating the first admin, you can optionally remove this key from production.
ADMIN_SETUP_KEY="replace_with_a_random_64_char_admin_setup_key_1234567890abcd"

# API Configuration
NEXT_PUBLIC_API_URL="http://localhost:5000"
# Optional server-only API URL for Next.js server components
API_URL="http://localhost:5000"
PORT=5000

# CORS
CORS_ORIGIN="http://localhost:3000,http://localhost:5000"

# Auth cookie behavior
# For split frontend/backend domains in production, use SameSite=None and Secure cookies.
AUTH_COOKIE_SAMESITE="none"
# Optional: set only when frontend and backend share a parent domain (example: .example.com)
# AUTH_COOKIE_DOMAIN=".example.com"

# Supabase (optional, for file storage)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your_anon_key"
SUPABASE_BUCKET_NAME="animah-uploads"

# Environment
NODE_ENV="development"
