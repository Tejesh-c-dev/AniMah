# =============================================================================
# AniMah - Environment Variables Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control - .env.example is the only file that should be committed.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL)
# -----------------------------------------------------------------------------
# DATABASE_URL: Connection string for the database (uses connection pooler)
# DIRECT_URL: Direct connection string (bypasses pooler, needed for Prisma Migrate)
DATABASE_URL="postgresql://[user]:[password]@[host]-pooler.neon.tech/[dbname]?sslmode=require&connect_timeout=15"
DIRECT_URL="postgresql://[user]:[password]@[host].neon.tech/[dbname]?sslmode=require&connect_timeout=15"

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# JWT_SECRET: Must be at least 32 characters (64 recommended).
# Generate with: openssl rand -base64 48
JWT_SECRET="replace_with_a_random_64_char_secret_for_jwt_signing_1234567890"

# ADMIN_SETUP_KEY: One-time use key to create the first admin account.
# Must be at least 32 characters. Keep this SECRET.
# Generate with: openssl rand -base64 48
ADMIN_SETUP_KEY="replace_with_a_random_64_char_admin_setup_key_1234567890abcd"

# -----------------------------------------------------------------------------
# API Base URL Configuration (REQUIRED for Vercel deployment)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_API_URL: Used by client-side (browser) code.
#   - Development: http://localhost:[backend-port]
#   - Production: Your backend server URL (e.g., https://api.yourdomain.com)
#
# API_URL: Used by server-side code (Server Components, API Routes).
#   - Can use internal service URLs not exposed to browser

# For LOCAL DEVELOPMENT:
NEXT_PUBLIC_API_URL="http://localhost:5000"
API_URL="http://localhost:5000"

# For VERCEL PRODUCTION - update these:
# NEXT_PUBLIC_API_URL="https://api.yourdomain.com"
# API_URL="https://api.yourdomain.com"

# -----------------------------------------------------------------------------
# Backend Server Configuration
# -----------------------------------------------------------------------------
PORT=5000
CORS_ORIGIN="http://localhost:3000,http://localhost:5000"

# -----------------------------------------------------------------------------
# Auth Cookie Configuration
# -----------------------------------------------------------------------------
# AUTH_COOKIE_SAMESITE: "none" for split-domain deployments (required for HTTPS)
AUTH_COOKIE_SAMESITE="none"
# AUTH_COOKIE_DOMAIN=".example.com" # Optional: for shared parent domain

# -----------------------------------------------------------------------------
# Supabase (Optional - for file/image storage)
# -----------------------------------------------------------------------------
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your_anon_key"
SUPABASE_BUCKET_NAME="animah-uploads"

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
NODE_ENV="development"
