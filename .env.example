# =============================================================================
# AniMah - Environment Variables Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control - .env.example is the only file that should be committed.
#
# IMPORTANT: 
# - For local development: All settings should point to localhost
# - For Vercel production: Override these in Vercel Project Settings → Environment Variables
# =============================================================================

# =============================================================================
# 🗄️  DATABASE (Neon PostgreSQL)
# =============================================================================
# These values come from your Neon dashboard: https://console.neon.tech

# DATABASE_URL: Runtime connection string (ALWAYS use the pooler endpoint)
#   Format: postgresql://user:password@host-pooler.neon.tech/dbname?params
#   - MUST include "-pooler" in hostname
#   - MUST include: sslmode=require&pgbouncer=true&connect_timeout=15
#   - Used by: Prisma client at runtime, server components, API routes
DATABASE_URL="postgresql://[user]:[password]@[project]-pooler.neon.tech/[dbname]?sslmode=require&pgbouncer=true&connect_timeout=15"

# DIRECT_URL: Direct connection (for migrations ONLY)
#   Format: postgresql://user:password@host.neon.tech/dbname?params
#   - DO NOT use in pooler for runtime (causes connection exhaustion)
#   - MUST include: sslmode=require&channel_binding=require&connect_timeout=15
#   - Used by: Prisma migrations (`prisma migrate`)
DIRECT_URL="postgresql://[user]:[password]@[project].neon.tech/[dbname]?sslmode=require&channel_binding=require&connect_timeout=15"

# =============================================================================
# 🔐 AUTHENTICATION
# =============================================================================

# JWT_SECRET: Secret key for signing JSON Web Tokens
#   Requirements:
#   - MUST be at least 32 characters (64 recommended)
#   - Generate with: openssl rand -base64 48
#   - Keep this SECRET - never commit to repo
#   - Used by: /api/auth routes, cookie signing
JWT_SECRET="[generate-with: openssl-rand-base64-48]"

# ADMIN_SETUP_KEY: One-time use key to create the first admin account
#   Requirements:
#   - MUST be at least 32 characters (64 recommended)
#   - Generate with: openssl rand -base64 48
#   - Keep this SECRET - never commit to repo
#   - Used by: POST /api/admin/setup (one-time only)
ADMIN_SETUP_KEY="[generate-with: openssl-rand-base64-48]"

# =============================================================================
# 🚀 API URL CONFIGURATION (CRITICAL FOR DEPLOYMENT)
# =============================================================================
# These URLs tell the frontend where to find the backend API.
# Different settings are needed for local dev vs production deployment.

# ─────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT (npm run dev)
# ─────────────────────────────────────────────────────────────────────────
# Set to your Express backend address. Runs on PORT (see below).

PORT=5002
NEXT_PUBLIC_API_URL="http://localhost:5002"
API_URL="http://localhost:5002"

# ─────────────────────────────────────────────────────────────────────────
# VERCEL PRODUCTION (Override in Vercel dashboard)
# ─────────────────────────────────────────────────────────────────────────
# IMPORTANT: Do NOT set these in .env for production!
# Set them in Vercel Project Settings → Environment Variables instead.
#
# If backend is deployed separately (e.g., on Render, Railway):
#   NEXT_PUBLIC_API_URL="https://api.yourdomain.com"    ← Backend server URL
#   API_URL="https://api.yourdomain.com"
#
# If backend is deployed to the SAME Vercel project:
#   You can omit these - Vercel will auto-use its domain via VERCEL_URL
#   Otherwise set to: https://your-vercel-app.vercel.app
#
# Examples:
#   ✅ Separate backend:        NEXT_PUBLIC_API_URL="https://animah-api.render.com"
#   ✅ Same Vercel project:     (omit, or set to deployment URL)
#   ❌ WRONG - localhost:       NEXT_PUBLIC_API_URL="http://localhost:5002"  (won't work!)

# =============================================================================
# 🌐 CORS CONFIGURATION
# =============================================================================
# Allowed origins for Cross-Origin Resource Sharing
# Format: comma-separated list of URLs (no trailing slashes)
# Used by: Express backend /middleware/cors

# Local development
CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001"

# For Vercel production, add your Vercel deployment URL:
# CORS_ORIGIN="https://your-vercel-app.vercel.app,https://yourdomain.com"

# =============================================================================
# 📋 QUICK SETUP CHECKLIST
# =============================================================================
# Local Development:
#   [ ] Copy this file: cp .env.example .env
#   [ ] Get Neon credentials: https://console.neon.tech
#   [ ] Replace [user], [password], [project], [dbname] in DATABASE_URL
#   [ ] Generate JWT_SECRET: openssl rand -base64 48
#   [ ] Generate ADMIN_SETUP_KEY: openssl rand -base64 48
#   [ ] Run: npm install
#   [ ] Run: npm run prisma:migrate (first time only)
#   [ ] Run: npm run dev
#
# Vercel Deployment:
#   [ ] Deploy frontend to Vercel (via GitHub)
#   [ ] Go to Vercel Project Settings → Environment Variables
#   [ ] Add ALL variables from this file (except PORT which is local-only)
#   [ ] Deploy separate backend (Render, Railway, etc.) - see deployment docs
#   [ ] Set NEXT_PUBLIC_API_URL to your backend server URL in Vercel
#   [ ] Trigger redeploy
#
# See VERCEL_DEPLOYMENT.md for detailed instructions

# -----------------------------------------------------------------------------
PORT=5000
CORS_ORIGIN="http://localhost:3000,http://localhost:5000"

# -----------------------------------------------------------------------------
# Auth Cookie Configuration
# -----------------------------------------------------------------------------
# AUTH_COOKIE_SAMESITE: "none" for split-domain deployments (required for HTTPS)
AUTH_COOKIE_SAMESITE="none"
# AUTH_COOKIE_DOMAIN=".example.com" # Optional: for shared parent domain

# -----------------------------------------------------------------------------
# Supabase (Optional - for file/image storage)
# -----------------------------------------------------------------------------
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your_anon_key"
SUPABASE_BUCKET_NAME="animah-uploads"

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
NODE_ENV="development"
